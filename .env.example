# ==========================================
# CENSO WEB - CONFIGURACIÓN DE ENTORNO
# ==========================================
# IMPORTANTE: Copia este archivo como .env y configura tus valores reales
# NO SUBAS .env a Git (debe estar en .gitignore)

# ==========================================
# DJANGO CORE SETTINGS
# ==========================================

# SECRET_KEY - Generar con: python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiar-esta-clave-secreta-en-produccion-por-una-muy-larga-y-aleatoria-de-50-caracteres-minimo

# DEBUG - SIEMPRE False en producción
DEBUG=True

# ALLOWED_HOSTS - Separar por comas sin espacios
ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# IMPORTANTE: La base de datos cambia automáticamente:
#   - DEBUG=True  → Usa SQLite (desarrollo local)
#   - DEBUG=False → Usa MySQL (producción PythonAnywhere)
#
# Para PRODUCCIÓN en PythonAnywhere, configurar:

# MySQL en PythonAnywhere
DB_NAME=tuusuario$censodb
DB_USER=tuusuario
DB_PASSWORD=tu_password_mysql_aqui
DB_HOST=tuusuario.mysql.pythonanywhere-services.com
DB_PORT=3306

# NOTA: Reemplazar "tuusuario" con tu username de PythonAnywhere
# El password es el que estableciste en PythonAnywhere → Databases

# ==========================================
# SECURITY SETTINGS
# ==========================================

# HTTPS/SSL (Activar en producción)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Para producción, cambiar a:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000

# ==========================================
# DATA ENCRYPTION
# ==========================================

# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=GENERA_UNA_KEY_FERNET_AQUI_CON_EL_COMANDO_DE_ARRIBA

# ==========================================
# SITE CONFIGURATION
# ==========================================

SITE_URL=http://127.0.0.1:8000
SITE_NAME=Censo Web

# ==========================================
# EMAIL CONFIGURATION
# ==========================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_de_gmail

# ==========================================
# REDIS CONFIGURATION
# ==========================================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Sentry (Opcional - para monitoreo de errores)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Log Level
LOG_LEVEL=INFO

# ==========================================
# CORS SETTINGS
# ==========================================

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# SESSION & SECURITY
# ==========================================

SESSION_COOKIE_AGE=86400
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# ==========================================
# INSTRUCCIONES
# ==========================================

# 1. COPIAR ESTE ARCHIVO:
#    cp .env.example .env
#
# 2. GENERAR SECRET_KEY:
#    python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# 3. GENERAR DATA_ENCRYPTION_KEY:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# 4. EDITAR .env CON TUS VALORES REALES
#
# 5. VERIFICAR .gitignore INCLUYE .env

