# Archivo de ejemplo de variables de entorno para PythonAnywhere
# Copiar este archivo como .env y llenar con tus valores reales

# ==========================================
# DATABASE - MySQL en PythonAnywhere
# ==========================================
DB_NAME=TU_USERNAME$censodb
DB_USER=TU_USERNAME
DB_PASSWORD=tu_password_mysql
DB_HOST=TU_USERNAME.mysql.pythonanywhere-services.com
DB_PORT=3306

# ==========================================
# DJANGO SETTINGS
# ==========================================
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-generada-aqui

# DEBUG - SIEMPRE False en producción
DEBUG=False

# ALLOWED_HOSTS - Tu dominio de PythonAnywhere
ALLOWED_HOSTS=TU_USERNAME.pythonanywhere.com

# ==========================================
# PATHS - Ajustar con tu username
# ==========================================
MEDIA_ROOT=/home/TU_USERNAME/censo-django/media
STATIC_ROOT=/home/TU_USERNAME/censo-django/staticfiles

# ==========================================
# REDIS (No disponible en plan gratuito)
# ==========================================
REDIS_ENABLED=False

# ==========================================
# EJEMPLO CON VALORES REALES
# ==========================================
# Si tu username es "censoindigenademo":
#
# DB_NAME=censoindigenademo$censodb
# DB_USER=censoindigenademo
# DB_PASSWORD=MiPassword123!
# DB_HOST=censoindigenademo.mysql.pythonanywhere-services.com
# DB_PORT=3306
#
# SECRET_KEY=django-insecure-8k2#m9n@x5p$q7w!e3r4t5y6u7i8o9p0
# DEBUG=False
# ALLOWED_HOSTS=censoindigenademo.pythonanywhere.com
#
# MEDIA_ROOT=/home/censoindigenademo/censo-django/media
# STATIC_ROOT=/home/censoindigenademo/censo-django/staticfiles

